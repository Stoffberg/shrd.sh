# shrd.sh API - Wrangler Configuration
# Copy this file to wrangler.toml and fill in your values

name = "shrd-api"
main = "src/index.ts"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]
workers_dev = true

# Optional: Add your custom domain route
# routes = [
#   { pattern = "shrd.yourdomain.com/*", zone_name = "yourdomain.com" }
# ]

[vars]
# REQUIRED: Set this to your deployment URL
BASE_URL = "https://shrd.yourdomain.com"

# Create these resources with:
#   wrangler kv:namespace create CONTENT
#   wrangler r2 bucket create shrd-storage
#   wrangler d1 create shrd-db

[[kv_namespaces]]
binding = "CONTENT"
id = "YOUR_KV_NAMESPACE_ID"

[[r2_buckets]]
binding = "STORAGE"
bucket_name = "shrd-storage"

[[d1_databases]]
binding = "DB"
database_name = "shrd-db"
database_id = "YOUR_D1_DATABASE_ID"
migrations_dir = "../../packages/db/migrations"
